{
  "app": {
    "executable": "build/MultiAgentPlatform.exe",
    "window_title": "多智能体协同推理与动态任务编排算法平台",
    "demo_mode_arg": "--demo",
    "window_size": [1400, 900],
    "startup_delay": 8,
    "action_delay": 1.5,
    "screenshot_dir": "screenshots"
  },
  "login": {
    "window_title": "多智能体协同推理与动态任务编排算法平台",
    "username_control": "txt-username",
    "password_control": "txt-password",
    "login_button": "btn-login",
    "auto_fill": true,
    "default_username": "chen_admin",
    "default_password": "Admin@2024"
  },
  "modules": [
    {"id": 1, "name": "智能体画像矩阵舱", "nav_control": "nav-module-1", "buttons": ["btn-refresh-matrix", "btn-export-matrix", "btn-filter-matrix", "btn-detail-matrix"]},
    {"id": 2, "name": "协同推理引擎3D中枢", "nav_control": "nav-module-2", "buttons": ["btn-run-reasoning", "btn-pause-reasoning", "btn-reset-reasoning", "btn-rotate-reasoning", "btn-detail-reasoning", "btn-export-reasoning"]},
    {"id": 3, "name": "动态任务编排中枢", "nav_control": "nav-module-3", "buttons": ["btn-create-task", "btn-assign-task", "btn-sort-task", "btn-execute-task"]},
    {"id": 4, "name": "消息分发总线", "nav_control": "nav-module-4", "buttons": ["btn-refresh-bus", "btn-filter-bus", "btn-broadcast-bus", "btn-clear-bus"]},
    {"id": 5, "name": "能力评估引擎", "nav_control": "nav-module-5", "buttons": ["btn-assess-run", "btn-assess-compare", "btn-export-assess", "btn-recalc-assess"]},
    {"id": 6, "name": "推理过程审计舱", "nav_control": "nav-module-6", "buttons": ["btn-audit-query", "btn-audit-export", "btn-audit-mark", "btn-audit-replay"]},
    {"id": 7, "name": "状态机流转监控中枢", "nav_control": "nav-module-7", "buttons": ["btn-transit-flow", "btn-transit-task", "btn-reset-state", "btn-export-state"]},
    {"id": 8, "name": "冲突消解仲裁引擎", "nav_control": "nav-module-8", "buttons": ["btn-detect-conflict", "btn-resolve-conflict", "btn-toggle-rule", "btn-history-conflict"]},
    {"id": 9, "name": "通信拓扑矩阵校验", "nav_control": "nav-module-9", "buttons": ["btn-refresh-comm", "btn-validate-comm", "btn-edit-comm", "btn-export-comm"]},
    {"id": 10, "name": "结果聚合校验引擎", "nav_control": "nav-module-10", "buttons": ["btn-aggregate-run", "btn-validate-aggregation", "btn-export-aggregation", "btn-detail-aggregation"]},
    {"id": 11, "name": "仿真推演沙盘舱", "nav_control": "nav-module-11", "buttons": ["btn-config-simulation", "btn-run-simulation", "btn-compare-simulation", "btn-refresh-simulation", "btn-play-simulation", "btn-pause-simulation", "btn-stop-simulation", "btn-step-simulation", "btn-reset-simulation"]},
    {"id": 12, "name": "系统效能审计矩阵", "nav_control": "nav-module-12", "buttons": ["btn-refresh-efficacy", "btn-export-efficacy", "btn-analyze-efficacy", "btn-report-efficacy"]}
  ],
